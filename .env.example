# ────────────────────────────────────────────────────────────────
# Console d'administration Atlas Studio
# ────────────────────────────────────────────────────────────────
# La console est INDÉPENDANTE du site vitrine mais RELIÉE au même
# backend Supabase. Renseignez ici EXACTEMENT les mêmes valeurs que
# celles utilisées par le site Atlas-Studio-Website afin de partager
# la même base de données, les mêmes comptes admin et les mêmes tables.
#
# Copiez ce fichier en `.env` puis remplacez les valeurs :
#   cp .env.example .env
# ────────────────────────────────────────────────────────────────

VITE_SUPABASE_URL=https://VOTRE-PROJET.supabase.co
VITE_SUPABASE_ANON_KEY=votre-cle-anon-publique
